# Multi-stage build for production readiness
FROM python:3.12-slim as base

# System dependencies layer
RUN apt-get update && apt-get install -y \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Install Poetry
RUN pip install poetry==2.1.3
ENV POETRY_NO_INTERACTION=1 \
    POETRY_VENV_IN_PROJECT=1 \
    POETRY_CACHE_DIR=/tmp/poetry_cache

WORKDIR /app

# Dependencies layer (cached when pyproject.toml unchanged)
COPY pyproject.toml poetry.lock ./
RUN poetry install --only=main --no-root && rm -rf $POETRY_CACHE_DIR

# Development stage
FROM base as development

# Install dev dependencies
RUN poetry install && rm -rf $POETRY_CACHE_DIR

# Create non-root user for security
RUN groupadd --gid 1000 django \
    && useradd --uid 1000 --gid django --shell /bin/bash --create-home django

# Set up application
COPY --chown=django:django . .

# PyCharm debugging support
EXPOSE 8000 5678

USER django

# Development command with auto-reload
CMD ["poetry", "run", "python", "manage.py", "runserver", "0.0.0.0:8000"]

# Production stage
FROM base as production

# Install production dependencies only
COPY pyproject.toml poetry.lock ./
RUN poetry install --only=main --no-root && rm -rf $POETRY_CACHE_DIR


# Create non-root user
RUN groupadd --gid 1000 django \
    && useradd --uid 1000 --gid django --shell /bin/bash --create-home django

# Copy application
COPY --chown=django:django . .

# Collect staticfiles files
# Перед запуском collectstatic нужно активировать виртуальное окружение
